<?xml version="1.0" encoding="utf-8"?>
<animated-selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_enabled="true"
        android:state_checked="true"
        android:id="@+id/on"
        android:drawable="@drawable/coui_btn_eye_on"/>
    <item
        android:state_enabled="true"
        android:state_checked="false"
        android:id="@+id/off"
        android:drawable="@drawable/coui_btn_eye_off"/>
    <item
        android:state_enabled="false"
        android:state_checked="false"
        android:drawable="@drawable/coui_btn_eye_off_disabled"/>
    <item
        android:state_enabled="false"
        android:state_checked="true"
        android:drawable="@drawable/coui_btn_eye_on_disabled"/>
    <transition
        android:drawable="@drawable/coui_btn_eye_off_anim"
        android:toId="@+id/off"
        android:fromId="@+id/on"/>
    <transition
        android:drawable="@drawable/coui_btn_eye_on_anim"
        android:toId="@+id/on"
        android:fromId="@+id/off"/>
</animated-selector>
