<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center_vertical"
    android:orientation="vertical"
    android:id="@+id/ll_history_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/coui_color_label_secondary"
        android:id="@+id/tx_start_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_8"
        android:fontFamily="sans-serif-medium"
        android:lineHeight="@dimen/sp_20"
        android:textFontWeight="500"/>
    <com.coloros.translate.ui.simultaneous.widget.TextBackgroundTextView
        android:textSize="@dimen/sp_14"
        android:textColor="@color/coui_color_label_primary"
        android:gravity="center_vertical"
        android:id="@+id/tx_from_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp_8"
        android:lineSpacingExtra="@dimen/dp_2"
        android:fontFamily="sans-serif-medium"
        android:lineHeight="@dimen/sp_20"
        android:textFontWeight="400"/>
    <com.coloros.translate.ui.simultaneous.widget.TextBackgroundTextView
        android:textAppearance="?attr/couiTextAppearanceButton"
        android:textSize="@dimen/sp_16"
        android:textColor="@color/coui_color_label_primary"
        android:gravity="center_vertical"
        android:id="@+id/tx_to_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="@dimen/dp_2"
        android:fontFamily="sans-serif-medium"
        android:lineHeight="22sp"
        android:textFontWeight="500"/>
</LinearLayout>
