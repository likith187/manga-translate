<?xml version="1.0" encoding="utf-8"?>
<com.coui.appcompat.panel.COUIPanelContentLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/coui_panel_content_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_content_wrapper"
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <FrameLayout
            android:layout_gravity="center_horizontal"
            android:id="@+id/drag_layout"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/coui_panel_drag_view_height"
            android:layout_marginTop="@dimen/coui_panel_drag_view_shadow_margin_top"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <View
                android:id="@+id/tv_drag_press_bg"
                android:background="@drawable/coui_pannel_press_shadow_bg"
                android:layout_width="@dimen/coui_panel_drag_view_shadow_width"
                android:layout_height="@dimen/coui_panel_drag_view_shadow_height"
                android:alpha="0"
                android:forceDarkAllowed="false"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/drag_img"
                android:paddingLeft="@dimen/coui_panel_drag_view_padding_horizontal"
                android:paddingTop="@dimen/coui_panel_drag_view_padding_vertical"
                android:paddingRight="@dimen/coui_panel_drag_view_padding_horizontal"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/coui_panel_drag_view"
                android:layout_centerInParent="true"/>
        </FrameLayout>
        <com.coui.appcompat.panel.COUIPanelBarView
            android:id="@+id/panel_drag_bar"
            android:layout_width="@dimen/coui_panel_bar_total_width"
            android:layout_height="@dimen/coui_panel_drag_view_width"
            android:translationZ="100dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/panel_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ImageView
        android:id="@+id/divider_line"
        android:background="?attr/couiColorDivider"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <com.coui.appcompat.buttonBar.COUIButtonBarLayout
        android:orientation="horizontal"
        android:id="@+id/bottom_bar"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/coui_alert_dialog_button_height">
        <LinearLayout
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <com.coui.appcompat.button.COUIButton
                android:id="@android:id/button3"
                android:singleLine="false"
                style="@style/COUIAlertDialogBottomButtonNewNormal"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/coui_dialog_button_divider_1"
            android:visibility="gone"
            style="@style/COUIAlertDialogBottomButtonDivider"/>
        <LinearLayout
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <com.coui.appcompat.button.COUIButton
                android:id="@android:id/button1"
                android:singleLine="false"
                style="@style/COUIAlertDialogBottomButtonNewNormal"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/coui_dialog_button_divider_2"
            android:visibility="gone"
            style="@style/COUIAlertDialogBottomButtonDivider"/>
        <LinearLayout
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <com.coui.appcompat.button.COUIButton
                android:id="@android:id/button2"
                android:singleLine="false"
                style="@style/COUIAlertDialogBottomButtonNewNormal"/>
        </LinearLayout>
    </com.coui.appcompat.buttonBar.COUIButtonBarLayout>
</com.coui.appcompat.panel.COUIPanelContentLayout>
