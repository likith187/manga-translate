<?xml version="1.0" encoding="utf-8"?>
<com.coui.appcompat.preference.COUICustomListSelectedLinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:coui="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/support_preference_min_height"
    android:paddingStart="@dimen/support_preference_title_padding_start"
    android:paddingEnd="@dimen/support_preference_title_padding_end">
    <FrameLayout
        android:layout_gravity="top"
        android:id="@+id/img_layout"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/PreferenceIcon">
        <com.coui.appcompat.imageview.COUIRoundImageView
            android:layout_gravity="top"
            android:id="@android:id/icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:importantForAccessibility="no"
            coui:couiType="round"/>
        <com.coui.appcompat.reddot.COUIHintRedDot
            android:layout_gravity="end|top"
            android:id="@+id/img_red_dot"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/support_preference_icon_red_dot_margin_top"
            android:layout_marginEnd="@dimen/support_preference_icon_red_dot_margin_top"/>
    </FrameLayout>
    <androidx.appcompat.widget.AppCompatCheckBox
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/coui_head_mark"
        android:focusable="false"
        android:visibility="gone"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true"
        android:button="@drawable/coui_btn_check_mark"
        android:paddingStart="0dp"
        android:layout_marginStart="-4dp"
        android:layout_marginEnd="@dimen/support_preference_mark_checkbox_margin_end"
        android:forceDarkAllowed="false"/>
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        style="@style/PreferenceContent">
        <TextView
            android:id="@android:id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/COUIPreferenceTitleStyle"/>
        <TextView
            android:id="@android:id/summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/support_preference_margin_between_line"
            android:layout_below="@android:id/title"
            android:layout_alignStart="@android:id/title"
            style="@style/COUIPreferenceSummaryStyle"/>
        <TextView
            android:id="@+id/assignment"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/support_preference_margin_between_line"
            android:layout_below="@android:id/summary"
            android:layout_alignStart="@android:id/title"
            android:forceDarkAllowed="false"
            style="@style/TextAppearance.COUI.List.Assignment"/>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@android:id/widget_frame"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</com.coui.appcompat.preference.COUICustomListSelectedLinearLayout>
