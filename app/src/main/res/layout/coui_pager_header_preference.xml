<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:coui="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:paddingTop="@dimen/support_preference_header_preference_padding_vertical"
    android:paddingBottom="@dimen/support_preference_header_preference_padding_vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/support_preference_header_preference_margin_top"
    android:paddingStart="@dimen/support_preference_title_padding_start"
    android:paddingEnd="@dimen/support_preference_title_padding_end">
    <com.coui.appcompat.imageview.COUIRoundImageView
        android:layout_gravity="center"
        android:id="@android:id/icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        coui:couiType="round"/>
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:id="@android:id/title"
            android:fadingEdge="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/COUIPreferenceTitleStyle"/>
        <TextView
            android:id="@android:id/summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@android:id/title"
            android:layout_alignStart="@android:id/title"
            style="@style/COUIPreferenceDescriptionStyle"/>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:id="@android:id/widget_frame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>
