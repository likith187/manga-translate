<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/coui_color_background_with_card"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.coui.appcompat.toolbar.COUIToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:supportTitle="@string/text_translate"
            app:supportTitleTextAppearance="@style/textAppearanceSecondTitle"/>
        <com.coloros.translate.widget.LanguageChooseView
            android:layout_gravity="center"
            android:id="@+id/choose_language_tablet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="200dp"/>
    </FrameLayout>
    <com.coloros.translate.widget.LanguageChooseView
        android:id="@+id/choose_language"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_12"
        android:paddingHorizontal="@dimen/dp_16"/>
    <com.coui.appcompat.grid.COUIPercentWidthFrameLayout
        android:id="@+id/frame_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginHorizontal="@dimen/dp_16">
        <RelativeLayout
            android:id="@+id/frame_translate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:transitionName="frame_trans">
            <RelativeLayout
                android:id="@+id/ori_frame"
                android:padding="@dimen/dp_16"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true">
                <EditText
                    android:textAppearance="@style/couiTextHeadlineS"
                    android:textColor="@color/coui_color_label_primary"
                    android:textColorHint="@color/coui_color_label_tertiary"
                    android:gravity="top"
                    android:id="@+id/input"
                    android:background="@null"
                    android:fadingEdgeLength="@dimen/coui_full_page_statement_tiny_scroll_fade_length"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_16"
                    android:minHeight="@dimen/dp_94"
                    android:hint="@string/text_translation_input_hint_new"
                    android:layout_alignParentTop="true"
                    android:inputType="textMultiLine"
                    android:textCursorDrawable="@drawable/color_cursor"
                    android:requiresFadingEdge="vertical"
                    android:layout_toStartOf="@+id/clear_ori"
                    android:layout_alignParentStart="true"
                    android:importantForAutofill="no"
                    android:lineHeight="@dimen/sp_26"
                    android:textFontWeight="500"/>
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/waiting_input"
                    android:visibility="gone"
                    android:layout_width="@dimen/dp_25"
                    android:layout_height="@dimen/dp_19"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true"
                    app:lottie_autoPlay="false"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/waiting_light"/>
                <ImageView
                    android:id="@+id/clear_ori"
                    android:paddingTop="@dimen/dp_1"
                    android:paddingBottom="@dimen/dp_9"
                    android:visibility="gone"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/clear_content"
                    android:layout_alignParentTop="true"
                    android:contentDescription="@string/clear"
                    android:layout_alignParentEnd="true"
                    android:paddingHorizontal="@dimen/dp_5"/>
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/ori_play_sound"
                    android:background="@drawable/bg_play_black"
                    android:visibility="gone"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:layout_below="@+id/input"
                    android:contentDescription="@string/play_sound_talk"
                    android:layout_alignParentStart="true"
                    android:forceDarkAllowed="false"
                    app:lottie_autoPlay="false"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/icon_play_black"/>
                <ImageView
                    android:id="@+id/icon_text_speak"
                    android:visibility="visible"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/icon_mic"
                    android:layout_below="@+id/input"
                    android:contentDescription="@string/click_to_speak"
                    android:layout_alignParentEnd="true"
                    android:transitionName="mic_trans"/>
                <RelativeLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/ai_btn"
                    android:clipChildren="false"
                    android:layout_width="@dimen/dp_132"
                    android:layout_height="@dimen/dp_64"
                    android:layout_marginBottom="-16dp"
                    android:layout_alignBottom="@+id/icon_text_speak"
                    android:layout_marginStart="@dimen/dp_32"
                    android:layout_toStartOf="@+id/icon_text_speak">
                    <ImageView
                        android:id="@+id/ai_btn_bg_nor"
                        android:background="@drawable/ai_btn_cn_nor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/ai_btn"/>
                    <ImageView
                        android:id="@+id/ai_btn_bg_on"
                        android:background="@drawable/ai_btn_cn_on"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/ai_btn"
                        android:alpha="0"/>
                    <ImageView
                        android:id="@+id/ai_btn_icon"
                        android:layout_width="@dimen/dp_18"
                        android:layout_height="@dimen/dp_18"
                        android:src="@drawable/icon_ai"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/ai_btn"
                        android:layout_marginStart="30dp"/>
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textAppearance="@style/couiTextButtonM"
                        android:textColor="@color/icon_black"
                        android:ellipsize="marquee"
                        android:id="@+id/ai_content"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_btn"
                        android:singleLine="true"
                        android:layout_centerVertical="true"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:contentDescription="@string/ai_btn"
                        android:layout_marginStart="@dimen/dp_4"
                        android:layout_marginEnd="@dimen/dp_32"
                        android:layout_toEndOf="@+id/ai_btn_icon"
                        android:textFontWeight="500"/>
                </RelativeLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:id="@+id/text_speak_frame"
                    android:background="@drawable/bg_play_blue_rectangle"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_32"
                    android:layout_below="@+id/input"
                    android:paddingStart="@dimen/dp_8"
                    android:paddingEnd="@dimen/dp_16"
                    android:layout_alignParentEnd="true">
                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottie_text_speak"
                        android:visibility="visible"
                        android:layout_width="@dimen/dp_32"
                        android:layout_height="@dimen/dp_32"
                        android:contentDescription="@string/click_to_stop_speak"
                        app:lottie_autoPlay="false"
                        app:lottie_loop="true"
                        app:lottie_rawRes="@raw/light_mic"/>
                    <com.coui.appcompat.textview.COUITextView
                        android:textAppearance="@style/couiTextButtonM"
                        android:textColor="@color/coui_color_label_theme_blue"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/end_speck_chinese"
                        android:layout_marginStart="@dimen/dp_4"/>
                </LinearLayout>
            </RelativeLayout>
            <View
                android:id="@+id/divider"
                android:background="@color/coui_color_divider"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:layout_below="@+id/ori_frame"
                android:layout_marginHorizontal="@dimen/dp_16"
                android:forceDarkAllowed="false"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/frame_result"
                android:padding="@dimen/dp_16"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_130"
                android:layout_below="@+id/ori_frame">
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/waiting_result"
                    android:visibility="gone"
                    android:layout_width="@dimen/dp_25"
                    android:layout_height="@dimen/dp_19"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:lottie_autoPlay="false"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/waiting_light"/>
                <com.coloros.translate.ui.texttranslation.widget.COUIAnimateTextView
                    android:textAppearance="@style/couiTextHeadlineM"
                    android:textColor="@color/coui_color_label_theme_blue"
                    android:gravity="bottom"
                    android:id="@+id/result"
                    android:fadingEdge="vertical"
                    android:fadingEdgeLength="@dimen/coui_full_page_statement_tiny_scroll_fade_length"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/dp_48"
                    android:requiresFadingEdge="vertical"
                    android:lineHeight="@dimen/sp_26"
                    android:textFontWeight="600"
                    app:layout_constraintTop_toTopOf="parent"/>
                <com.coui.appcompat.textview.COUITextView
                    android:textSize="@dimen/dp_12"
                    android:textStyle="normal"
                    android:textColor="@color/icon_black"
                    android:id="@+id/result_sign"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/convert_generate_oppo"
                    android:alpha="0.3"
                    android:layout_marginVertical="@dimen/dp_16"
                    app:layout_constraintBottom_toTopOf="@+id/divider_sign"
                    app:layout_constraintTop_toBottomOf="@+id/result"/>
                <View
                    android:id="@+id/divider_sign"
                    android:background="@color/coui_color_divider"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_1"
                    android:layout_marginBottom="@dimen/dp_16"
                    android:layout_marginHorizontal="@dimen/dp_16"
                    android:forceDarkAllowed="false"
                    app:layout_constraintBottom_toTopOf="@+id/result_play_sound"/>
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/result_play_sound"
                    android:background="@drawable/bg_play_blue"
                    android:visibility="visible"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:contentDescription="@string/play_sound_talk"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/enlarge"
                    app:lottie_autoPlay="false"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/icon_play_blue"/>
                <ImageView
                    android:id="@+id/copy"
                    android:background="@drawable/circle_bg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/icon_copy"
                    android:scaleType="centerInside"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/copy_talk"
                    android:layout_marginEnd="@dimen/dp_16"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/enlarge"
                    app:layout_constraintTop_toTopOf="@+id/enlarge"/>
                <ImageView
                    android:id="@+id/enlarge"
                    android:background="@drawable/circle_bg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/icon_enlarge"
                    android:scaleType="centerInside"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/enlarge_talk"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
                <androidx.constraintlayout.widget.Group
                    android:id="@+id/result_btn_group"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="result_play_sound, copy, enlarge"/>
                <androidx.constraintlayout.widget.Group
                    android:id="@+id/ai_sign_group"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="divider_sign, result_sign"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </RelativeLayout>
    </com.coui.appcompat.grid.COUIPercentWidthFrameLayout>
    <com.coui.appcompat.grid.COUIPercentWidthRelativeLayout
        android:id="@+id/frame_histories"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_24">
        <com.coui.appcompat.textview.COUITextView
            android:textAppearance="@style/couiTextButtonM"
            android:textColor="@color/coui_color_label_primary"
            android:id="@+id/recent_histories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recent_histories"
            android:layout_marginStart="@dimen/dp_32"
            android:layout_marginEnd="@dimen/dp_16"
            android:textFontWeight="500"/>
        <com.coui.appcompat.textview.COUITextView
            android:textAppearance="@style/couiTextButtonM"
            android:textColor="@color/coui_color_label_secondary"
            android:id="@+id/clear_histories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/clear_histories"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_32"
            android:layout_alignParentEnd="true"
            android:paddingHorizontal="@dimen/dp_4"
            android:textFontWeight="500"/>
        <androidx.recyclerview.widget.COUIRecyclerView
            android:id="@+id/list_history_recyclerview"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/dp_8"
            android:listSelector="@android:color/transparent"
            android:layout_below="@+id/recent_histories"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
    </com.coui.appcompat.grid.COUIPercentWidthRelativeLayout>
    <com.coui.appcompat.grid.COUIPercentWidthRelativeLayout
        android:id="@+id/frame_none_histories"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_24">
        <com.coui.appcompat.textview.COUITextView
            android:textAppearance="@style/couiTextButtonM"
            android:textColor="@color/coui_color_label_primary"
            android:id="@+id/recent_histories_none"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recent_histories"
            android:layout_marginStart="@dimen/dp_32"
            android:layout_marginEnd="@dimen/dp_16"
            android:textFontWeight="500"/>
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/empty_img"
            android:layout_width="@dimen/dp_280"
            android:layout_height="@dimen/dp_200"
            android:layout_marginTop="@dimen/dp_40"
            android:layout_below="@+id/recent_histories_none"
            android:layout_centerHorizontal="true"
            android:contentDescription="@string/text_empty_guide_text"
            app:lottie_autoPlay="true"
            app:lottie_loop="false"
            app:lottie_rawRes="@raw/empty_history"/>
        <com.coui.appcompat.textview.COUITextView
            android:textAppearance="@style/couiTextButtonM"
            android:textSize="@dimen/sp_16"
            android:textColor="@color/coui_color_label_primary"
            android:gravity="center"
            android:id="@+id/empty_guide_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/text_empty_guide_text"
            android:layout_below="@+id/empty_img"
            android:layout_centerHorizontal="true"/>
    </com.coui.appcompat.grid.COUIPercentWidthRelativeLayout>
</LinearLayout>
