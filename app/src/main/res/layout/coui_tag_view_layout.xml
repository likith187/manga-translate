<?xml version="1.0" encoding="utf-8"?>
<com.coui.appcompat.tagview.COUITagBackgroundView xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:layout_gravity="center"
    android:id="@+id/tagBackground"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingStart="3dp"
    android:paddingEnd="3dp">
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/tagLeftImageView"
        android:layout_width="5dp"
        android:layout_height="10dp"
        android:layout_marginTop="3dp"
        android:layout_marginBottom="3dp"
        android:scaleType="centerCrop"
        android:layout_marginEnd="2dp"/>
    <TextView
        android:ellipsize="end"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/tagTextView"
        android:padding="0dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:includeFontPadding="false"
        android:forceDarkAllowed="false"
        style="@style/couiTextTag"/>
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/tagImageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"/>
</com.coui.appcompat.tagview.COUITagBackgroundView>
