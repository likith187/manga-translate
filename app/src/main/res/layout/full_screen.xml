<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_activity_enlarge"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.coui.appcompat.button.COUIButton
        android:id="@+id/close"
        android:background="@drawable/icon_enlarge_quit"
        android:layout_width="@dimen/dp_48"
        android:layout_height="@dimen/dp_48"
        android:layout_marginTop="@dimen/dp_24"
        android:scaleType="centerInside"
        android:adjustViewBounds="true"
        android:contentDescription="@string/screen_function_name_exit"
        android:layout_marginStart="@dimen/dp_36"
        android:layout_marginEnd="@dimen/dp_24"
        android:layout_alignParentEnd="true"/>
    <TextView
        android:textAppearance="@style/COUIAppbarTitleStyle.Expanded"
        android:textSize="68sp"
        android:textColor="@color/coui_color_label_theme_blue"
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:lineSpacingExtra="@dimen/dp_4"
        android:layout_marginStart="@dimen/dp_64"
        android:layout_toStartOf="@+id/close"
        android:layout_alignParentStart="true"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="@dimen/sp_28"
        android:autoSizeMaxTextSize="@dimen/sp_68"
        android:textFontWeight="600"/>
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/play"
        android:background="@drawable/bg_enlarge_play"
        android:visibility="visible"
        android:layout_width="@dimen/dp_48"
        android:layout_height="@dimen/dp_48"
        android:layout_marginBottom="@dimen/dp_24"
        android:layout_alignParentBottom="true"
        android:contentDescription="@string/play_sound_talk"
        android:layout_marginStart="@dimen/dp_36"
        android:layout_marginEnd="@dimen/dp_24"
        android:layout_alignParentEnd="true"
        app:lottie_autoPlay="false"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/icon_play_blue"/>
</RelativeLayout>
