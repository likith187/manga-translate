<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:forceDarkAllowed="false">
    <com.oplus.anim.EffectiveAnimationView
        android:id="@+id/coui_anim"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <com.coui.appcompat.textview.COUITextView
        android:textColor="?attr/couiColorLabelSecondary"
        android:id="@+id/coui_text"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/couiTextAppearanceBody"/>
    <ImageView
        android:id="@+id/coui_image"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</FrameLayout>
