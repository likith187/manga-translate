<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:id="@+id/rl_item_rootView"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="64dp">
    <RelativeLayout
        android:id="@+id/download_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/dp_16">
        <com.coui.appcompat.progressbar.COUIInstallLoadProgress
            android:gravity="center"
            android:id="@+id/btn_download"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:max="100"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            style="?attr/couiInstallLoadProgressSmallStyle"/>
        <com.coui.appcompat.button.COUIButton
            android:id="@+id/btn_delete"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="52dp"
            android:text="@string/eto_action_delete"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_alignParentEnd="true"
            style="@style/Widget.COUI.Button.SmallDownload"/>
        <LinearLayout
            android:orientation="vertical"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:layout_toStartOf="@+id/btn_download"
            android:layout_alignParentStart="true"
            android:paddingVertical="10dp">
            <TextView
                android:textAppearance="?attr/couiTextHeadlineXS"
                android:textSize="16sp"
                android:textColor="?attr/couiColorLabelPrimary"
                android:id="@+id/package_item_name"
                android:fadingEdge="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/package_item_name_width"
                android:lineHeight="22dp"
                android:textFontWeight="500"/>
            <TextView
                android:textAppearance="?attr/couiTextBodyM"
                android:textSize="14sp"
                android:textColor="?attr/couiColorLabelSecondary"
                android:ellipsize="end"
                android:id="@+id/package_item_size"
                android:fadingEdge="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:lineHeight="20dp"
                android:textFontWeight="400"/>
        </LinearLayout>
    </RelativeLayout>
    <View
        android:layout_gravity="center_horizontal"
        android:id="@+id/divider_line"
        android:background="?attr/couiColorDivider"
        android:layout_width="match_parent"
        android:layout_height="@dimen/coui_list_divider_height"
        android:layout_below="@+id/download_item"
        android:layout_marginHorizontal="@dimen/dp_16"
        android:forceDarkAllowed="false"/>
</RelativeLayout>
