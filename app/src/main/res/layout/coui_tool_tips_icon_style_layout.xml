<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ScrollView
        android:id="@+id/scrollView"
        android:scrollbars="none"
        android:fadingEdgeLength="@dimen/coui_tooltips_scroll_fading_length"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/coui_tooltips_icon_scroll_margin_top"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:requiresFadingEdge="vertical">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <com.coui.appcompat.imageview.COUIRoundImageView
                    android:id="@+id/iv_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="2dp"
                    android:scaleType="fitCenter"
                    android:layout_marginStart="12dp"
                    app:couiBorderRadius="@dimen/coui_tooltips_imageview_radius"
                    app:couiType="round"/>
                <TextView
                    android:textAppearance="?attr/couiTextHeadlineXS"
                    android:textColor="?attr/couiColorLabelPrimary"
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="62dp"
                    android:layout_marginEnd="16dp"/>
                <TextView
                    android:textAppearance="?attr/couiTextBodyM"
                    android:textColor="?attr/couiColorLabelSecondary"
                    android:id="@+id/contentTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_below="@+id/tv_title"
                    android:layerType="hardware"
                    android:textAlignment="viewStart"
                    android:layoutDirection="locale"
                    android:layout_marginStart="62dp"
                    android:layout_marginEnd="16dp"/>
            </RelativeLayout>
        </LinearLayout>
    </ScrollView>
    <TextView
        android:textAppearance="?attr/couiTextButtonM"
        android:textColor="?attr/couiColorLabelTheme"
        android:ellipsize="end"
        android:layout_gravity="end"
        android:id="@+id/tv_dismiss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="10dp"
        android:maxLines="2"
        android:layout_marginStart="50dp"
        android:layout_marginEnd="4dp"/>
</LinearLayout>
