      "version": "1.0.2",
      "versionCode": "1000002",
      "tags": [
        "翻译",
        "屏幕翻译"
      ],
      "description": "屏幕翻译属于页面类设置项，主要功能是供用户唤出屏幕翻译的控件，执行全屏文字的识别与翻译。打开屏幕翻译是屏幕翻译设置项的一个具体操作指令，主要用于帮助用户一键跳转到屏幕翻译页面。。",
      "invoke": {
        "protocol": {
          "type": "ApiProxy",
          "apiType": "ANDROID_START_SERVICE",
          "attributes": {
            "packageName": "com.coloros.translate",
            "extras": [
              {
                "key": "extra_from_package",
                "type": "string",
                "value": "com.heytap.speechassist"
              }
            ],
            "action": "oplus.intent.action.GLOBAL_TRANSLATION",
            "runInForeground": true
          }
        },
        "protocolVariants": [
          {
            "type": "ApiProxy",
            "apiType": "ANDROID_CONTENT_PROVIDER",
            "attributes": {
              "authority": "com.coloros.translate.BreenoAbilityProvider",
              "type": "CALL",
              "method": "open_screen_translation"
            }
          }
        ]
      }
